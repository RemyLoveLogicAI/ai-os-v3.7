# AI OS v3.7 — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.

# ── Ollama Fleet (local, zero cost) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_TARGET=default

# Fleet model overrides (defaults shown — matches your OpenClaw aliases)
OLLAMA_MODEL_AGENT=hermes3:70b
OLLAMA_MODEL_REASON=deepseek-r1:32b
OLLAMA_MODEL_CODE=qwen2.5:32b
OLLAMA_MODEL_DEFAULT=qwen2.5:14b
OLLAMA_MODEL_FAST=gemma3:4b

# ── Cloud Fallbacks (optional) ───────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000
AI_OS_ENV=production
LOG_LEVEL=INFO
